---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import { SITE } from '../../consts';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { resolveAuthor } from '../../lib/authors';
import { buildBaseGraph, buildCollectionPageGraph, toGraph } from '../../lib/seo-graph';

const posts = (await getCollection('posts', ({ data }) => {
    if (import.meta.env.PROD) return !data.draft && data.published <= new Date();
    return true;
  }))
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const postsWithMeta = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    const author = await resolveAuthor(post.data.author);
    return { post, readingTime: remarkPluginFrontmatter.readingTime as string, author };
  })
);

const canonicalURL = new URL('/posts', SITE.url).href;
const graph = toGraph([
  ...buildBaseGraph(),
  ...buildCollectionPageGraph({
    title: 'Blog',
    description: `All posts from ${SITE.title}.`,
    canonicalUrl: canonicalURL,
  }),
]);
---

<Base title="Blog" description={`All posts from ${SITE.title}.`} graph={graph}>
  <header class="mb-4">
    <h1 class="text-4xl sm:text-5xl font-bold leading-tight tracking-tight mb-4">
      All Posts
    </h1>
    <p class="font-(family-name:--font-ui) text-sm text-(--color-muted)">
      {posts.length} articles
    </p>
  </header>

  <div class="divide-y divide-(--color-border)">
    {postsWithMeta.map(({ post, readingTime, author }) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        published={post.data.published}
        slug={post.id}
        tags={post.data.tags}
        draft={post.data.draft}
        readingTime={readingTime}
        updated={post.data.updated}
        author={author}
      />
    ))}
  </div>
</Base>
