---
export const prerender = true;
import type { InferGetStaticPropsType } from 'astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Prose from '../../components/Prose.astro';
import TagList from '../../components/TagList.astro';
import AuthorCard from '../../components/AuthorCard.astro';
import ShareLinks from '../../components/ShareLinks.astro';
import { SITE } from '../../consts';
import { resolveAuthor } from '../../lib/authors';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => {
    if (import.meta.env.PROD) return !data.draft && data.published <= new Date();
    return true;
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props as Props;
const { Content, remarkPluginFrontmatter } = await render(post);

const author = await resolveAuthor(post.data.author);
const readingTime = remarkPluginFrontmatter.readingTime as string;
const readingTimeMinutes = remarkPluginFrontmatter.readingTimeMinutes as number;
const wordCount = remarkPluginFrontmatter.wordCount as number;

const formattedDate = post.data.published.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = post.data.updated?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = new URL(`/posts/${post.id}`, SITE.url).href;

const allPosts = (await getCollection('posts', ({ data }) => {
    if (import.meta.env.PROD) return !data.draft && data.published <= new Date();
    return true;
  }))
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const prevPost = allPosts[currentIndex + 1];
const nextPost = allPosts[currentIndex - 1];
---

<Base
  title={post.data.title}
  description={post.data.description}
  post={{
    ...post.data,
    author,
    readingTimeMinutes,
    wordCount,
  }}
  flush={true}
>
  <div class="pt-10 pb-12">
    <div class="mx-auto max-w-3xl px-6 mb-6">
      <a
        id="post-back-link"
        href="/posts"
        aria-label="Back to all posts"
        class="inline-flex items-center gap-2 font-(family-name:--font-ui) text-sm text-(--color-muted) no-underline hover:text-(--color-accent-interactive) transition-colors"
      >
        <span aria-hidden="true">←</span>
        <span>Back</span>
      </a>
    </div>

    <div class="post-grid">
      <article transition:name={`post-${post.id}`}>
        <header class="col-[content] mb-10">
          <div class="relative">
            <h1
              transition:name={`post-title-${post.id}`}
              class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-tight tracking-tight mb-3"
            >
              {post.data.title}
            </h1>
            {post.data.draft && (
              <span transition:name={`post-${post.id}-draft`} class="font-(family-name:--font-ui) text-xs font-bold uppercase tracking-widest px-2.5 mb-2 py-1 max-w-max rounded bg-amber-400 text-amber-950 hidden lg:block">
                Draft
              </span>
            )}
          </div>
          <p transition:name={`post-desc-${post.id}`} class="font-(family-name:--font-body) text-[1.25rem] leading-relaxed text-(--color-muted) mt-0 mb-4">
            {post.data.description}
          </p>
          <div transition:name={`post-byline-${post.id}`} class="flex flex-wrap items-center gap-x-3 gap-y-1 font-(family-name:--font-ui) text-sm text-(--color-muted)">
            {author.url ? (
              <a href={author.url} class="no-underline text-(--color-muted) hover:text-(--color-accent-interactive) transition-colors">
                {author.name}
              </a>
            ) : (
              <span>{author.name}</span>
            )}
            <span class="text-(--color-border)">·</span>
            <time datetime={post.data.published.toISOString()}>
              {formattedDate}
            </time>
            <span class="text-(--color-border)">·</span>
            <span>{readingTime}</span>
            {formattedUpdated && (
              <>
                <span class="text-(--color-border)">·</span>
                <span>Updated {formattedUpdated}</span>
              </>
            )}
          </div>
        </header>

        {post.data.image && (
          <figure class="col-[wide] mb-10">
            <Image
              src={post.data.image}
              alt=""
              width={1200}
              height={675}
              widths={[400, 800, 1200]}
              sizes="(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px"
              loading="eager"
              decoding="async"
              class="w-full h-auto rounded-lg"
            />
          </figure>
        )}

        <Prose>
          <Content />
        </Prose>
      </article>
    </div>

    <div class="mx-auto max-w-3xl px-6 mt-16">
      <hr class="border-t border-(--color-border) mb-8" />
      <TagList tags={post.data.tags} />
      <AuthorCard author={author} />
      <ShareLinks url={canonicalURL} title={post.data.title} />
    </div>

    {(prevPost || nextPost) && (
      <nav aria-label="Post pagination" class="mx-auto max-w-3xl px-6 mt-8 pt-8 border-t border-(--color-border) grid grid-cols-2 gap-8">
        {prevPost ? (
          <a href={`/posts/${prevPost.id}`} class="group no-underline">
            <span class="font-(family-name:--font-ui) text-xs text-(--color-muted) uppercase tracking-wide">Older</span>
            <p class="font-(family-name:--font-headline) text-lg font-medium mt-1 group-hover:text-(--color-accent-interactive) transition-colors m-0">
              {prevPost.data.title}
            </p>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/posts/${nextPost.id}`} class="group no-underline text-right">
            <span class="font-(family-name:--font-ui) text-xs text-(--color-muted) uppercase tracking-wide">Newer</span>
            <p class="font-(family-name:--font-headline) text-lg font-medium mt-1 group-hover:text-(--color-accent-interactive) transition-colors m-0">
              {nextPost.data.title}
            </p>
          </a>
        ) : <div />}
      </nav>
    )}
  </div>
</Base>
