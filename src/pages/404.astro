---
export const prerender = true;
import Base from '../layouts/Base.astro';
import Prose from '../components/Prose.astro';
import FuzzyRedirect from '@jdevalk/astro-seo-graph/FuzzyRedirect.astro';
---

<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <Prose>
    <h1>Page Not Found</h1>

    <FuzzyRedirect suggestionText="Did you mean" />

    <p>
      Sorry, the page you're looking for doesn't exist or has been moved.
    </p>

    <p>
      You can head back to the <a href="/">home page</a> or browse the
      <a href="/posts/">blog</a>.
    </p>
  </Prose>

  <style is:global>
    #fuzzy-redirect:empty { display: none; }
    #fuzzy-redirect {
      font-family: var(--font-ui);
      font-size: 1.125rem;
      font-weight: 600;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      border-radius: 0.5rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
    }
    #fuzzy-redirect a {
      color: var(--color-accent-interactive);
    }
  </style>
</Base>
