---
import { SITE } from '../consts';
import { AUTHOR } from '../lib/author';
import type { PostAuthor } from '../lib/authors';

interface Props {
  title: string;
  description: string;
  image?: string;
  post?: {
    published: Date;
    updated?: Date;
    image?: string;
    tags?: string[];
    readingTimeMinutes?: number;
    wordCount?: number;
    author?: PostAuthor;
  };
  person?: boolean;
}

const { title, description, image, post, person = false } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedImage = image ?? post?.image ?? '/og-default.png';
const imageURL = new URL(resolvedImage, Astro.site);
const isArticle = !!post;

const pageTitle = title === 'Home'
  ? `${SITE.title} | Home`
  : `${title} | ${SITE.title}`;

const personId = `${SITE.url}/#person`;

// JSON-LD: Person (about page only)
const personSchema = !person ? null : {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': personId,
  name: AUTHOR.name,
  alternateName: AUTHOR.alternateName,
  url: AUTHOR.url,
  jobTitle: AUTHOR.jobTitle,
  worksFor: {
    '@type': 'Organization',
    name: AUTHOR.worksFor.name,
    url: AUTHOR.worksFor.url,
  },
  homeLocation: {
    '@type': 'Place',
    name: AUTHOR.location,
  },
  alumniOf: AUTHOR.alumniOf.map((school) => ({
    '@type': 'EducationalOrganization',
    name: school.name,
    url: school.url,
  })),
  affiliation: AUTHOR.affiliations.map((org) => ({
    '@type': 'Organization',
    name: org.name,
    url: org.url,
  })),
  sameAs: AUTHOR.sameAs,
};

// JSON-LD: WebSite (all pages)
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  url: Astro.site?.href,
  description: SITE.description,
  inLanguage: SITE.language,
  author: { '@id': personId },
};

// JSON-LD: BlogPosting (article pages)
const postAuthor = post?.author;
const articleAuthorSchema = postAuthor?.isSiteAuthor !== false
  ? { '@id': personId }
  : { '@type': 'Person' as const, name: postAuthor.name, ...(postAuthor.url ? { url: postAuthor.url } : {}) };

const articleSchema = post ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: canonicalURL.href,
  image: imageURL.href,
  datePublished: post.published.toISOString(),
  ...(post.updated ? { dateModified: post.updated.toISOString() } : {}),
  ...(post.wordCount ? { wordCount: post.wordCount } : {}),
  ...(post.readingTimeMinutes ? { timeRequired: `PT${post.readingTimeMinutes}M` } : {}),
  ...(post.tags?.length ? { keywords: post.tags.join(', ') } : {}),
  author: articleAuthorSchema,
  publisher: { '@id': personId },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalURL.href,
  },
} : null;

// JSON-LD: BreadcrumbList (article pages)
const breadcrumbSchema = post ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Posts', item: `${SITE.url}/posts` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
} : null;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author.name} />
<link rel="canonical" href={canonicalURL.href} />

<!-- Open Graph -->
<meta property="og:type" content={isArticle ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL.href} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={SITE.language} />
{post?.published && <meta property="article:published_time" content={post.published.toISOString()} />}
{post?.updated && <meta property="article:modified_time" content={post.updated.toISOString()} />}
{post && <meta property="article:author" content={SITE.author.url} />}
{post?.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
{post?.tags?.[0] && <meta property="article:section" content={post.tags[0]} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL.href} />

<!-- JSON-LD -->
{personSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
)}
<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{articleSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}
{breadcrumbSchema && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
