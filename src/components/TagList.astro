---
import { toTagUrl } from '../lib/tags';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <section class="tag-list" aria-label="Post tags">
    <span class="tag-label">Tags</span>
    <div class="tag-pills">
      {tags.map((tag) => (
        <a href={toTagUrl(tag)} class="tag-pill">
          {tag}
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .tag-label {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .tag-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-pill {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--color-accent-atmosphere);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    transition: border-color 0.15s, color 0.15s;
  }

  .tag-pill:hover {
    color: var(--color-accent-interactive);
    border-color: var(--color-accent-interactive);
  }
</style>
