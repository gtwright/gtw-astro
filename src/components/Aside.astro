---
interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<div class="aside-wrapper">
  <aside class="aside-note">
    {label && <p class="aside-label">{label}</p>}
    <div class="aside-body">
      <slot />
    </div>
  </aside>
</div>

<style>
  .aside-wrapper {
    position: relative;
  }

  .aside-note {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-muted);
    background: color-mix(in oklab, var(--color-text) 4%, var(--color-main-bg));
    padding: 1rem 1.25rem;
    border-radius: 6px;
    margin-bottom: 1.5em;
  }

  /* Wide screens: position in right margin, collapse wrapper height */
  @media (min-width: 80rem) {
    .aside-wrapper {
      height: 0;
      overflow: visible;
    }

    .aside-note {
      position: absolute;
      left: calc(100% + 2rem);
      width: 220px;
      background: transparent;
      padding: 0;
      border-radius: 0;
      margin-bottom: 0;
    }
  }

  .aside-label {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }

  .aside-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .aside-body :global(p) {
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 0.5em;
  }
</style>
