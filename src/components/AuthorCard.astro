---
import { Icon } from 'astro-icon/components';
import { AUTHOR, SOCIAL } from '../lib/author';
import type { PostAuthor } from '../lib/authors';

interface Props {
  author: PostAuthor;
}

const { author } = Astro.props;
---

<section class="author-card" aria-label="About the author">
  <div class="author-info">
    <p class="author-name">
      {author.url ? <a href={author.url}>{author.name}</a> : author.name}
    </p>
    {author.isSiteAuthor && (
      <p class="author-title">{AUTHOR.jobTitle}, {AUTHOR.worksFor.name}</p>
    )}
    {author.bio && <p class="author-bio">{author.bio}</p>}
    {author.isSiteAuthor && (
      <div class="author-links">
        {SOCIAL.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
            <Icon name={link.icon} size={18} />
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .author-card {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
    margin-bottom: 2rem;
  }

  .author-info {
    font-family: var(--font-ui);
  }

  .author-name {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .author-name a {
    color: var(--color-text);
    text-decoration: none;
  }

  .author-name a:hover {
    color: var(--color-accent-interactive);
  }

  .author-title {
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }

  .author-bio {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .author-links {
    display: flex;
    gap: 0.75rem;
  }

  .author-links a {
    color: var(--color-accent-atmosphere);
    transition: color 0.15s;
  }

  .author-links a:hover {
    color: var(--color-accent-interactive);
  }
</style>
