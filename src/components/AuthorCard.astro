---
import type { PostAuthor } from '../lib/authors';

interface Props {
  author: PostAuthor;
}

const { author } = Astro.props;
---

<section class="author-card" aria-label="About the author">
  <div class="author-info">
    <p class="author-name">
      By {author.url ? <a href={author.url}>{author.name}</a> : author.name}
    </p>
    {author.bio && <p class="author-bio">{author.bio}</p>}
  </div>
</section>

<style>
  .author-card {
    margin: 0;
  }

  .author-info {
    font-family: var(--font-ui);
  }

  .author-name {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.25rem;
  }

  .author-name a {
    color: var(--color-text);
    text-decoration: none;
  }

  .author-name a:hover {
    color: var(--color-accent-interactive);
  }

  .author-bio {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>
