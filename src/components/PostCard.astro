---
import { toTagUrl } from '../lib/tags';

interface Props {
  title: string;
  description?: string;
  published: Date;
  slug: string;
  tags?: string[];
  draft?: boolean;
  readingTime?: string;
  variant?: 'compact' | 'full';
  headingLevel?: 2 | 3;
}

const {
  title,
  description,
  published,
  slug,
  tags = [],
  draft,
  readingTime,
  variant = 'compact',
  headingLevel = 3,
} = Astro.props;

const Heading = `h${headingLevel}` as 'h2' | 'h3';

const formattedDate = published.toLocaleDateString('en-US', {
  year: 'numeric',
  month: variant === 'full' ? 'long' : 'short',
  day: 'numeric',
});
---

<article class={`post-card post-card-${variant}`}>
  <div class="post-card-body">
    <Heading class="post-card-title m-0 mb-1">
      <a href={`/posts/${slug}/`} class="post-card-link" transition:name={`post-title-${slug}`}>
        {draft && <span class="sr-only">[Draft] </span>}{title}
      </a>
    </Heading>
    {variant === 'full' && description && (
      <p class="post-card-desc m-0 mb-2">
        {description}
      </p>
    )}
    <div class="post-card-meta">
      <time datetime={published.toISOString()}>{formattedDate}</time>
      {readingTime && (
        <>
          <span class="post-card-divider">·</span>
          <span>{readingTime}</span>
        </>
      )}
      {draft && (
        <>
          <span class="post-card-divider">·</span>
          <span class="post-card-draft">Draft</span>
        </>
      )}
    </div>
    {variant === 'full' && tags.length > 0 && (
      <div class="post-card-meta post-card-tags">
        <span>Tagged</span>
        {tags.map((tag, i) => (
          <>
            {i > 0 && <span class="post-card-divider">·</span>}
            <a href={toTagUrl(tag)} class="post-card-tag">{tag}</a>
          </>
        ))}
      </div>
    )}
  </div>
  <span class="post-card-arrow" aria-hidden="true">→</span>
</article>

<style>
  .post-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: transparent;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-card:has(.post-card-link:hover) {
    transform: scale(1.015);
    border-color: color-mix(in oklab, var(--color-accent-interactive) 50%, var(--color-border));
    box-shadow: 0 2px 16px -4px color-mix(in oklab, var(--color-accent-interactive) 20%, transparent);
  }

  .post-card:has(.post-card-link:focus-visible) {
    outline: 2px solid var(--color-accent-interactive);
    outline-offset: 2px;
  }

  .post-card-body {
    flex: 1;
    min-width: 0;
  }

  .post-card-title {
    font-family: var(--font-headline);
    font-variation-settings: "opsz" 48, "wght" 600, "SOFT" 50;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .post-card-full .post-card-title {
    font-size: 1.5rem;
  }

  @media (min-width: 640px) {
    .post-card-compact .post-card-title {
      font-size: 1.5rem;
    }
    .post-card-full .post-card-title {
      font-size: 1.75rem;
    }
  }

  .post-card-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .post-card-link::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 8px;
  }

  .post-card-link:focus-visible {
    outline: none;
  }

  .post-card:has(.post-card-link:hover) .post-card-link {
    color: var(--color-accent-interactive);
  }

  .post-card-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .post-card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .post-card-tags {
    margin-top: 0.25rem;
  }

  .post-card-tag {
    position: relative;
    z-index: 1;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .post-card-tag:hover {
    color: var(--color-accent-interactive);
  }

  .post-card-divider {
    color: var(--color-border);
  }

  .post-card-draft {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent-interactive);
  }

  .post-card-arrow {
    font-family: var(--font-ui);
    font-weight: 400;
    color: var(--color-muted);
    flex-shrink: 0;
    pointer-events: none;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .post-card:has(.post-card-link:hover) .post-card-arrow {
    color: var(--color-accent-interactive);
    transform: translateX(4px);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card,
    .post-card-arrow,
    .post-card-link {
      transition: none;
    }
    .post-card:has(.post-card-link:hover) {
      transform: none;
    }
    .post-card:has(.post-card-link:hover) .post-card-arrow {
      transform: none;
    }
  }
</style>
