---
import { transformProps } from '@unpic/core';
import { getMediaMeta, getPlaceholder, resolveImageSrc } from '../lib/media';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  caption?: string;
  credit?: string;
  size?: 'standard' | 'wide' | 'full' | 'small';
  loading?: 'lazy' | 'eager';
}

const { src, alt, caption, credit, size = 'standard', loading = 'lazy' } = Astro.props;

const isLocal = typeof src === 'object';
const rawSrc = isLocal ? (src as ImageMetadata).src : src;
const resolvedSrc = isLocal ? rawSrc : resolveImageSrc(rawSrc);
const meta = isLocal ? null : getMediaMeta(rawSrc);
const placeholder = isLocal ? undefined : getPlaceholder(rawSrc);

const width = isLocal ? (src as ImageMetadata).width : (meta?.width ?? 1200);
const height = isLocal ? (src as ImageMetadata).height : (meta?.height ?? 675);

const imgAttrs = transformProps({
  src: resolvedSrc,
  width,
  height,
  alt,
  loading,
  layout: 'constrained',
});
---

<figure class:list={[size !== 'standard' && size]}>
  <div
    class="figure-img-wrapper"
    style={placeholder ? `background-image:url(${placeholder});background-size:cover;background-position:center;aspect-ratio:${width}/${height};border-radius:8px;overflow:hidden` : undefined}
  >
    <img {...imgAttrs as any} decoding="async" />
  </div>
  {(caption || credit) && (
    <figcaption>
      {caption && <Fragment set:html={caption} />}
      {credit && <span class="figure-credit"><Fragment set:html={credit} /></span>}
    </figcaption>
  )}
</figure>
