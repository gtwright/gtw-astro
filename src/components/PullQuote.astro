---
interface Props {
  attribution?: string;
}

const { attribution } = Astro.props;
---

<figure class="pull-quote">
  <div class="quote-mark" aria-hidden="true">&ldquo;</div>
  <blockquote>
    <slot />
  </blockquote>
  {attribution && (
    <figcaption>&mdash; {attribution}</figcaption>
  )}
</figure>

<style>
  .pull-quote {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0 0.5rem;
    padding: 1.5rem 0;
    margin: 2em 0;
  }

  .quote-mark {
    grid-row: 1 / -1;
    font-family: var(--font-headline);
    font-size: 4.5rem;
    line-height: 0.8;
    color: var(--color-accent-interactive);
    align-self: start;
  }

  .pull-quote blockquote {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    line-height: 1.4;
    font-style: normal;
    color: var(--color-text);
    border: none;
    padding: 0;
    margin: 0;
  }

  .pull-quote blockquote :global(p) {
    margin: 0;
  }

  figcaption {
    grid-column: 1 / -1;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
    text-align: right;
  }
</style>
