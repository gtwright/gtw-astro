---
import '@fontsource-variable/fraunces/full.css';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono';
import '../styles/global.css';
import { SITE } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '@jdevalk/astro-seo-graph/Seo.astro';
import { ClientRouter } from 'astro:transitions';
import PostHog from '../components/posthog.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  article?: {
    publishedTime: Date;
    modifiedTime?: Date;
    tags?: readonly string[];
    section?: string;
  };
  graph?: Record<string, unknown> | null;
  flush?: boolean;
}

const { title, description, ogImage, ogImageAlt, article, graph, flush = false } = Astro.props;

const pageTitle = title === 'Home'
  ? `${SITE.title} | Home`
  : `${title} | ${SITE.title}`;

const pathname = Astro.url.pathname.replace(/(?<=.)\/+$/, '');
const canonicalURL = new URL(pathname, Astro.site);

// OG image: explicit prop or default
const imageURL = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og-default.png', Astro.site).href;
---

<!doctype html>
<html lang={SITE.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo
      title={pageTitle}
      description={description}
      canonical={canonicalURL.href}
      ogType={article ? 'article' : 'website'}
      ogImage={imageURL}
      ogImageAlt={ogImageAlt ?? title}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName={SITE.title}
      locale="en_US"
      twitter={{ card: 'summary_large_image' }}
      article={article ? {
        publishedTime: article.publishedTime,
        ...(article.modifiedTime ? { modifiedTime: article.modifiedTime } : {}),
        authors: [SITE.author.url],
        ...(article.tags?.length ? { tags: [...article.tags] } : {}),
        ...(article.section ? { section: article.section } : {}),
      } : undefined}
      author={SITE.author.name}
      graph={graph}
      extraLinks={[
        { rel: 'icon', type: 'image/svg+xml', href: '/favicon.svg' },
        { rel: 'sitemap', href: '/sitemap-index.xml' },
        { rel: 'alternate', type: 'application/rss+xml', title: SITE.title, href: '/rss.xml' },
      ]}
    />
    <PostHog />
    <ClientRouter fallback="animate"/>
  </head>
  <body class="min-w-[320px] min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:rounded focus:bg-accent-atmosphere focus:px-4 focus:py-2 focus:text-main-bg focus:font-ui focus:text-sm"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1 bg-main-bg">
      <div class:list={[!flush && "mx-auto max-w-3xl px-6 pt-10 pb-12"]}>
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
